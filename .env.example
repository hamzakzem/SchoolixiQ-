# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SENTRY_DSN: Required for Sentry Error Tracking.
VITE_SENTRY_DSN=""

# FIREBASE_SERVICE_ACCOUNT: Required for Admin Auth operations (create/delete users)
# Obtain these from Firebase Console -> Project Settings -> Service Accounts -> Generate Private Key
FIREBASE_PROJECT_ID="yala-safari-iq"
FIREBASE_CLIENT_EMAIL="your-service-account@yala-safari-iq.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
BOOTSTRAP_ADMIN_EMAILS="hamzakazem1999@gmail.com"
GEMINI_API_KEY=""

# SMTP Email Configuration (Optional - fallback to Firestore system_notifications collection)
# Setup these to receive real email notifications automatically for new subscriptions/registrations.
# If using Gmail, use smtp.gmail.com, port 587 (or 465 with true secure), and an App Password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-character-app-password"
SMTP_FROM="your-email@gmail.com"
