{
  "name": "schoolixiq-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "node -e \"require('fs').copyFileSync('../server.ts','server.ts')\" && esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=./server.mjs",
    "start": "node server.mjs",
    "verify": "node ../scripts/verify-backend-build.mjs"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase-admin": "^13.8.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "esbuild": "0.25.12",
    "typescript": "~5.8.2"
  },
  "overrides": {
    "esbuild": "0.25.12"
  }
}
