rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Packages: readable by anyone, writeable by authenticated users (admins/superadmins)
    match /packages/{packageId} {
      allow read, get, list: if true;
      allow write: if request.auth != null;
    }

    // 2. System Settings: configuration is public (branding, logo, support, etc.), writeable by auth
    match /system/{document=**} {
      allow read, get, list: if true;
      allow write: if request.auth != null;
    }

    // 3. Schools: basic school details, featured status, contact info can be queried from the login page footer
    match /schools/{schoolId=**} {
      allow read, get, list: if true;
      allow write: if request.auth != null;
    }

    // 4. Students can be retrieved individually for student card verify via public QR scanners
    match /students/{studentId} {
      allow read, get, list: if true;
      allow write: if request.auth != null;
    }

    // 5. Unauthenticated landing page subscription/registration requests
    match /registrations/{registrationId=**} {
      allow create: if true;
      allow read, get, list, update, delete: if request.auth != null;
    }

    // Default rule for all other private collections requiring user session
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
