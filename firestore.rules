rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidEmail(email) { return email is string && email.size() <= 256 && email.matches('^.+@.+\\..+$'); }
    function getUserEmail() { 
      return ('email' in request.auth.token && request.auth.token.email is string) ? request.auth.token.email.lower() : ''; 
    }
    
    function isMasterAdmin() {
      return isSignedIn() && getUserEmail() in [
        "hamzakazem1999@gmail.com", "hamzakazem973@gmail.com", "scooopyiq@gmail.com"
      ];
    }
    
    function getUserData() {
      return (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }

    function isSchoolActive(schoolId) {
      let schoolDoc = exists(/databases/$(database)/documents/schools/$(schoolId)) 
          ? get(/databases/$(database)/documents/schools/$(schoolId)).data 
          : null;
      return schoolDoc != null && schoolDoc.get('status', '') == 'active';
    }
    
    function hasRoleIn(roles) {
      let data = getUserData();
      return data != null && ('role' in data) && data.role in roles;
    }

    function getSchoolId() {
      let data = getUserData();
      let docSchoolId = (data != null && 'schoolId' in data) ? data.schoolId : null;
      return (docSchoolId != null && docSchoolId != '') ? docSchoolId : (('schoolId' in request.auth.token) ? request.auth.token.schoolId : '');
    }
    
    function getUserRole() {
      let data = getUserData();
      let docRole = (data != null && 'role' in data) ? data.role : null;
      return (docRole != null && docRole != '') ? docRole : (('role' in request.auth.token) ? request.auth.token.role : '');
    }

    function getTokenRole() { 
      return 'role' in request.auth.token ? request.auth.token.role : ''; 
    }
    function getTokenSchoolId() { 
      return 'schoolId' in request.auth.token ? request.auth.token.schoolId : ''; 
    }

    function isSystemAssistant() {
      return isSignedIn() && ((getTokenRole() == 'assistant' && getTokenSchoolId() == '') || (getUserRole() == 'assistant' && getSchoolId() == ''));
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        isMasterAdmin() || 
        getTokenRole() == 'superadmin' ||
        getUserRole() == 'superadmin' ||
        isSystemAssistant() ||
        request.auth.uid in ["ArbxvuSjySdr6AeiUFa7bi6CYTk1", "IrAmEHNuOeQHigG5wGpUvttzz5K2", "E31eRIwjNdfXpeS9UC0nffHOVMz1"]
      );
    }

    function isSchoolAdmin(schoolId) {
      return isSignedIn() && (
        (getTokenSchoolId() == schoolId && getTokenRole() in ['admin', 'assistant']) ||
        (getSchoolId() == schoolId && getUserRole() in ['admin', 'assistant'])
      );
    }

    function isSchoolStaff(schoolId) {
      return isSignedIn() && (
        (getTokenSchoolId() == schoolId && getTokenRole() in ['admin', 'assistant', 'teacher', 'staff']) ||
        (getSchoolId() == schoolId && getUserRole() in ['admin', 'assistant', 'teacher', 'staff'])
      );
    }

    function hasPackagePermission(schoolId, permission) {
      let schoolDoc = exists(/databases/$(database)/documents/schools/$(schoolId)) 
          ? get(/databases/$(database)/documents/schools/$(schoolId)).data 
          : null;
      let planId = schoolDoc != null ? schoolDoc.get('planId', 'basic') : 'basic';
      let pkgDoc = exists(/databases/$(database)/documents/packages/$(planId)) 
          ? get(/databases/$(database)/documents/packages/$(planId)).data 
          : null;
      return pkgDoc != null ? pkgDoc.get('permissions', {}).get(permission, false) == true : false;
    }

    function isStaffWithPerm(schoolId, perm) {
      return isSchoolStaff(schoolId) && hasPackagePermission(schoolId, perm);
    }
    
    function isAdminWithPerm(schoolId, perm) {
      return isSchoolAdmin(schoolId) && hasPackagePermission(schoolId, perm);
    }
    function isParentOf(studentId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/students/$(studentId)) && (
               request.auth.uid in get(/databases/$(database)/documents/students/$(studentId)).data.get('parentIds', []) || 
               (getUserEmail() != '' && getUserEmail() == get(/databases/$(database)/documents/students/$(studentId)).data.get('parentEmail', ''))
             );
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (getUserEmail() != '' && resource != null && resource.data.get('email', '') == getUserEmail()) ||
        (getSchoolId() != '' && getSchoolId() == resource.data.get('schoolId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        (getSchoolId() != '' && getSchoolId() == resource.data.get('schoolId', '')) ||
        resource.data.get('role', '') == 'superadmin' ||
        (getUserEmail() != '' && resource.data.get('email', '') == getUserEmail())
      );
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && (
          request.resource.data.get('role', '') in ['parent', 'teacher', 'admin', 'staff', 'assistant'] ||
          (request.resource.data.get('role', '') == 'superadmin' && !exists(/databases/$(database)/documents/users/metadata))
        )) ||
        isSuperAdmin()
      );
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (request.auth.uid == userId && 
         request.resource.data.get('role', '') == resource.data.get('role', '') && (
           request.resource.data.get('schoolId', '') == resource.data.get('schoolId', '') ||
           resource.data.get('schoolId', '') == '' ||
           !('schoolId' in resource.data)
         )) ||
        (isSchoolAdmin(resource.data.get('schoolId', '')) && 
         request.resource.data.get('schoolId', '') == resource.data.get('schoolId', ''))
      );
      allow delete: if isSuperAdmin() || 
                    (isSchoolAdmin(resource.data.get('schoolId', '')) && resource.data.get('role', '') == 'parent') ||
                    (isSignedIn() && resource.data.get('email', '') == getUserEmail());
    }

    match /subscriptionRequests/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && (resource == null || resource.data.get('adminEmail', '') == getUserEmail() || resource.data.get('schoolId', '') == getSchoolId()));
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }
    
    match /schools/{schoolId} {
      allow get: if isSignedIn() || (resource != null && resource.data.get('status', '') == 'active');
      allow list: if isSignedIn() || (resource != null && resource.data.get('status', '') == 'active');
      allow create: if isSuperAdmin() || (isSignedIn() && (getUserRole() == 'admin' || getTokenRole() == 'admin' || request.resource.data.get('ownerUid', '') == request.auth.uid || request.resource.data.get('adminEmail', '') == getUserEmail()));
      allow update, delete: if isSuperAdmin() || isSchoolStaff(schoolId) || (isSignedIn() && resource.data.get('ownerUid', '') == request.auth.uid);
    }

    match /packages/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /registrations/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if true;
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }
    
    match /orders/{id} {
      allow get: if isSignedIn() && (isSuperAdmin() || resource.data.get('parentId', '') == request.auth.uid || isSchoolStaff(resource.data.get('schoolId', '')));
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.get('parentId', '') == request.auth.uid || isSchoolStaff(resource.data.get('schoolId', '')));
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || (isSignedIn() && isSchoolStaff(resource.data.get('schoolId', '')));
      allow delete: if isSuperAdmin();
    }

    match /students/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isStaffWithPerm(resource.data.get('schoolId', ''), 'students_view') || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        getUserEmail() == resource.data.get('parentEmail', '') ||
        (getUserData() != null && id in getUserData().get('studentIds', []))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        (resource.data.get('schoolId', '') != null && isSchoolStaff(resource.data.get('schoolId', ''))) || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        getUserEmail() == resource.data.get('parentEmail', '') ||
        false ||
        // Allow searching for a student while restricting bulk scraping
        (request.query.limit <= 1)
      );
      allow write: if isSuperAdmin() || (isSchoolActive(request.resource.data.get('schoolId', '')) && (isSignedIn() && isStaffWithPerm(request.resource.data.get('schoolId', ''), 'students_edit'))) || (
        isSignedIn() && 
        getUserEmail() == resource.data.get('parentEmail', '')
      ) || isParentOf(id);
    }

    match /grades/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', '')) ||
        isParentOf(resource.data.get('studentId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', ''))
      );
      allow create: if isSuperAdmin() || (isSchoolActive(request.resource.data.get('schoolId', '')) && isSignedIn() && isSchoolStaff(request.resource.data.get('schoolId', '')));
      allow update: if isSuperAdmin() || (isSchoolActive(request.resource.data.get('schoolId', '')) && isSignedIn() && isSchoolStaff(resource.data.get('schoolId', '')) && isSchoolStaff(request.resource.data.get('schoolId', '')));
      allow delete: if isSuperAdmin() || (isSchoolActive(resource.data.get('schoolId', '')) && isSignedIn() && isSchoolStaff(resource.data.get('schoolId', '')));
    }

    match /attendance/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isStaffWithPerm(resource.data.get('schoolId', ''), 'attendance_track') || 
        getUserRole() == 'parent' ||
        (getUserData() != null && resource.data.get('schoolId', '') == getUserData().get('schoolId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        getUserRole() == 'parent' ||
        false
      );
      allow write: if isSuperAdmin() || (isSignedIn() && isStaffWithPerm(request.resource.data.get('schoolId', ''), 'attendance_track'));
    }

    function isParentOfClass(schoolId, classId) {
       // Check if any of the parent's linked students are in this class
       return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          // This is a bit complex for a rule, but let's try to verify if the parent has students
          getUserData().get('studentIds', []).size() > 0
       );
    }

    match /announcements/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        resource.data.get('schoolId', '') == getSchoolId() ||
        getUserRole() == 'parent' ||
        (resource.data.get('target', '') == 'individual' && (
          resource.data.get('targetStudentId', '') in getUserData().get('studentIds', []) ||
          resource.data.get('targetParentId', '') == request.auth.uid
        ))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        resource.data.get('schoolId', '') == getSchoolId() ||
        getUserRole() == 'parent' ||
        (resource.data.get('target', '') == 'individual' && (
          resource.data.get('targetStudentId', '') in getUserData().get('studentIds', []) ||
          resource.data.get('targetParentId', '') == request.auth.uid
        ))
      );
      allow write: if isSuperAdmin() || (isSchoolActive(request.resource.data.get('schoolId', '')) && isSignedIn() && isSchoolStaff(request.resource.data.get('schoolId', '')));
    }

    match /payments/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isStaffWithPerm(resource.data.get('schoolId', ''), 'tuition_fees') || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        getUserEmail() == resource.data.get('parentEmail', '') ||
        isParentOf(resource.data.get('studentId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        getUserEmail() == resource.data.get('parentEmail', '') ||
        false
      );
      allow write: if isSuperAdmin() || (isSignedIn() && isStaffWithPerm(request.resource.data.get('schoolId', ''), 'tuition_fees'));
    }
    
    match /notifications/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.get('userId', '') == request.auth.uid || isSuperAdmin());
    }

    match /notification_preferences/{id} {
      allow read, write: if isSignedIn() && (
        (resource == null && (request.resource.data.get('parentId', '') == request.auth.uid || isSuperAdmin())) || 
        (resource != null && (resource.data.get('parentId', '') == request.auth.uid || isSuperAdmin()))
      );
    }

    match /homework/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isStaffWithPerm(resource.data.get('schoolId', ''), 'homework_and_tasks') || 
        resource.data.get('schoolId', '') == getSchoolId() ||
        // Parents can see homework for their students' classes
        (getUserData() != null && resource.data.get('schoolId', '') == getUserData().get('schoolId', '') )
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        resource.data.get('schoolId', '') == getSchoolId() ||
        // Parents can see homework for their students' classes
        (getUserData() != null && resource.data.get('schoolId', '') == getUserData().get('schoolId', '') ) ||
        (getUserEmail() != null && resource.data.get('schoolId', '') != null) // Simplification for allowing parents to fetch their students homeworks by schoolId constraint usually done in frontend. The app uses `isSchoolStaff` but parents aren't staff, we need to allow them if they query by schoolId.
      );
      allow write: if isSuperAdmin() || (isSignedIn() && ((request.resource != null && isStaffWithPerm(request.resource.data.get('schoolId', ''), 'homework_and_tasks')) || (resource != null && isStaffWithPerm(resource.data.get('schoolId', ''), 'homework_and_tasks'))));
      allow delete: if isSuperAdmin() || (isSignedIn() && isStaffWithPerm(resource.data.get('schoolId', ''), 'homework_and_tasks'));
      allow update: if isSuperAdmin() || (isSignedIn() && ((request.resource != null && isStaffWithPerm(request.resource.data.get('schoolId', ''), 'homework_and_tasks')) || (resource != null && isStaffWithPerm(resource.data.get('schoolId', ''), 'homework_and_tasks')))) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hiddenFor']));
    }

    match /advanced_reports/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isStaffWithPerm(resource.data.get('schoolId', ''), 'advanced_reports') || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', '')) ||
        isParentOf(resource.data.get('studentId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', ''))
      );
      allow write: if isSuperAdmin() || (isSignedIn() && ((request.resource != null && isStaffWithPerm(request.resource.data.get('schoolId', ''), 'advanced_reports')) || (resource != null && isStaffWithPerm(resource.data.get('schoolId', ''), 'advanced_reports'))));
      allow delete: if isSuperAdmin() || (isSignedIn() && isStaffWithPerm(resource.data.get('schoolId', ''), 'advanced_reports'));
    }

    match /id_cards/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) ||
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', '')) ||
        isParentOf(resource.data.get('studentId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) ||
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', ''))
      );
      allow write: if isSuperAdmin() || (isSignedIn() && ((request.resource != null && isSchoolStaff(request.resource.data.get('schoolId', ''))) || (resource != null && isSchoolStaff(resource.data.get('schoolId', ''))))) || isParentOf(id);
      allow delete: if isSuperAdmin() || (isSignedIn() && (resource != null && isSchoolStaff(resource.data.get('schoolId', ''))));
    }

    match /teacher_reports/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isStaffWithPerm(resource.data.get('schoolId', ''), 'student_evaluation_reports') || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', '')) ||
        isParentOf(resource.data.get('studentId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', ''))
      );
      allow write: if isSuperAdmin() || (isSignedIn() && ((request.resource != null && isStaffWithPerm(request.resource.data.get('schoolId', ''), 'student_evaluation_reports')) || (resource != null && isStaffWithPerm(resource.data.get('schoolId', ''), 'student_evaluation_reports'))));
      allow delete: if isSuperAdmin() || (isSignedIn() && isStaffWithPerm(resource.data.get('schoolId', ''), 'student_evaluation_reports'));
    }
    
    match /installments/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isStaffWithPerm(resource.data.get('schoolId', ''), 'tuition_fees') || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        getUserEmail() == resource.data.get('parentEmail', '') ||
        isParentOf(resource.data.get('studentId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        getUserEmail() == resource.data.get('parentEmail', '') ||
        false
      );
      allow write: if isSuperAdmin() || (isSignedIn() && isStaffWithPerm(request.resource.data.get('schoolId', ''), 'tuition_fees'));
    }

    match /market/{id} {
      allow get: if isSignedIn() && (isSuperAdmin() || resource.data.get('schoolId', '') == getSchoolId() || (getUserData() != null && resource.data.get('schoolId', '') == getUserData().get('schoolId', '')) || getUserRole() == 'parent');
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.get('schoolId', '') == getSchoolId() || getUserRole() == 'parent');
      allow write: if isSuperAdmin() || (isSignedIn() && isAdminWithPerm(request.resource.data.get('schoolId', ''), 'marketplace_ordering'));
    }

    match /payroll/{id} {
      allow get: if isSignedIn() && (isSuperAdmin() || isAdminWithPerm(resource.data.get('schoolId', ''), 'staff_payroll'));
      allow list: if isSignedIn() && (isSuperAdmin() || isSchoolStaff(resource.data.get('schoolId', '')));
      allow write: if isSuperAdmin() || (isSignedIn() && isAdminWithPerm(request.resource.data.get('schoolId', ''), 'staff_payroll'));
    }

    match /inventory/{id} {
      allow get: if isSignedIn() && (isSuperAdmin() || isStaffWithPerm(resource.data.get('schoolId', ''), 'inventory_and_assets'));
      allow list: if isSignedIn() && (isSuperAdmin() || isSchoolStaff(resource.data.get('schoolId', '')));
      allow write: if isSuperAdmin() || (isSignedIn() && isAdminWithPerm(request.resource.data.get('schoolId', ''), 'inventory_and_assets'));
    }

    match /classes/{id} {
      allow get: if isSignedIn() && (isSuperAdmin() || isStaffWithPerm(resource.data.get('schoolId', ''), 'automated_schedules') || (getUserData() != null && resource.data.get('schoolId', '') == getUserData().get('schoolId', '')));
      allow list: if isSignedIn() && (isSuperAdmin() || (getUserData() != null && resource.data.get('schoolId', '') == getUserData().get('schoolId', '')));
      allow write: if isSuperAdmin() || (isSignedIn() && (
        (request.resource != null && (isAdminWithPerm(request.resource.data.get('schoolId', ''), 'automated_schedules') || isSchoolStaff(request.resource.data.get('schoolId', '')))) ||
        (resource != null && (isAdminWithPerm(resource.data.get('schoolId', ''), 'automated_schedules') || isSchoolStaff(resource.data.get('schoolId', ''))))
      ));
    }

    match /behavior_reports/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isStaffWithPerm(resource.data.get('schoolId', ''), 'behavior_management') || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', '')) ||
        isParentOf(resource.data.get('studentId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', ''))
      );
      allow write: if isSuperAdmin() || (isSignedIn() && isStaffWithPerm(request.resource.data.get('schoolId', ''), 'behavior_management'));
      allow delete: if isSuperAdmin();
    }

    match /subjects/{id} {
      allow get: if isSignedIn() && (isSuperAdmin() || resource.data.get('schoolId', '') == getSchoolId());
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.get('schoolId', '') == getSchoolId());
      allow write: if isSuperAdmin() || (isSignedIn() && isSchoolAdmin(request.resource.data.get('schoolId', '')));
    }

    match /student_archives/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        isStaffWithPerm(resource.data.get('schoolId', ''), 'exams_and_results') || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', '')) ||
        isParentOf(resource.data.get('studentId', ''))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        isSchoolStaff(resource.data.get('schoolId', '')) || 
        request.auth.uid in resource.data.get('parentIds', []) ||
        (getUserEmail() == resource.data.get('parentEmail', ''))
      );
      allow write: if isSuperAdmin() || (isSignedIn() && (isSchoolAdmin(request.resource.data.get('schoolId', '')) || isStaffWithPerm(request.resource.data.get('schoolId', ''), 'exams_and_results')));
      allow delete: if isSuperAdmin() || (isSignedIn() && (isSchoolAdmin(resource.data.get('schoolId', '')) || isStaffWithPerm(resource.data.get('schoolId', ''), 'exams_and_results')));
    }
    
    match /system/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /system_messages/{id} {
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        (getSchoolId() == resource.data.get('schoolId', '') && (
          isSchoolStaff(resource.data.get('schoolId', '')) ||
          resource.data.get('conversationId', '').matches('.*' + request.auth.uid + '.*') ||
          resource.data.get('receiverId', '') == request.auth.uid ||
          resource.data.get('senderId', '') == request.auth.uid
        ))
      );
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        (getSchoolId() == resource.data.get('schoolId', '') && (
          isSchoolStaff(resource.data.get('schoolId', '')) ||
          resource.data.get('conversationId', '').matches('.*' + request.auth.uid + '.*') ||
          resource.data.get('receiverId', '') == request.auth.uid ||
          resource.data.get('senderId', '') == request.auth.uid
        ))
      );
      allow create: if isSignedIn() && (
        isSuperAdmin() || 
        (getSchoolId() == request.resource.data.get('schoolId', '') && 
         request.resource.data.get('senderId', '') == request.auth.uid)
      );
      allow update: if isSuperAdmin() || (
        isSignedIn() &&
        (resource.data.get('receiverId', '') == request.auth.uid || 
        (resource.data.get('receiverId', '') == 'admin' && isSchoolAdmin(resource.data.get('schoolId', '')))) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
      );
      allow delete: if isSuperAdmin();
    }
    
    // Default fallback
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
