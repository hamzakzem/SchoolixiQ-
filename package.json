{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:web",
    "build:full": "npm run build:web && npm run build:server",
    "build:web": "vite build && npm run stage:apk",
    "stage:apk": "node scripts/stage-apk.mjs",
    "stage:apk:require": "node scripts/stage-apk.mjs --require",
    "verify:web-build": "node scripts/verify-web-build.mjs",
    "build:server": "npm run build --prefix backend && node -e \"const fs=require('fs'); fs.mkdirSync('dist',{recursive:true}); fs.copyFileSync('backend/server.mjs','dist/server.mjs')\"",
    "preview": "vite preview",
    "start": "node dist/server.mjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@sentry/react": "^10.53.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.10",
    "@types/compression": "^1.8.1",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^11.3.1",
    "firebase-admin": "^13.8.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.0.1",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.6",
    "react-router-dom": "^7.14.2",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "0.25.12",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "overrides": {
    "esbuild": "0.25.12"
  }
}
