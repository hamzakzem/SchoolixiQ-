DirectoryIndex index.html index.php

# --- MIME types (Vite hashed bundles must not be served as text/plain) ---
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType application/json .json
  AddType application/manifest+json .webmanifest
  AddType application/vnd.android.package-archive .apk
</IfModule>

# --- Hostinger HTTP/2: disable server compression on large JS/CSS bundles ---
# mod_deflate on shared hosting can corrupt Content-Length over HTTP/2 (ERR_HTTP2_PROTOCOL_ERROR).
<IfModule mod_setenvif.c>
  SetEnvIfNoCase Request_URI "^/assets/.*\.(js|mjs|css|map)$" no-gzip dont-vary
  SetEnvIfNoCase Request_URI "\.(js|mjs|css|map)$" no-gzip dont-vary
  SetEnvIfNoCase Request_URI "^/assets/.*\.(js|mjs|css|map)$" no-brotli
  SetEnvIfNoCase Request_URI "\.(js|mjs|css|map)$" no-brotli
</IfModule>

<IfModule mod_deflate.c>
  # Never force DEFLATE on already-minified bundles.
  SetEnvIfNoCase Request_URI "^/assets/.*\.(js|mjs|css|map)$" no-gzip dont-vary
  SetEnvIfNoCase Request_URI "\.(gif|jpe?g|png|webp|ico|woff2?|ttf|eot|svg|mp4|pdf|zip)$" no-gzip dont-vary
</IfModule>

<IfModule mod_brotli.c>
  SetEnvIfNoCase Request_URI "^/assets/.*\.(js|mjs|css|map)$" no-brotli
</IfModule>

# --- Cache: fresh HTML shell, long-lived hashed assets ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
  <Files "index.html">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>

  <Files "manifest.json">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </Files>

  # Service worker must never be cached as immutable — otherwise CACHE_NAME bumps never reach clients.
  <Files "sw.js">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>
</IfModule>

# --- SPA routing: never rewrite real /assets/* files to index.html ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^assets/ - [L]
  RewriteRule ^downloads/ - [L]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
