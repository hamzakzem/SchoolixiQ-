rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Default Deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return isSignedIn() && firestore.exists(userPath());
    }

    function userData() {
      return userDocExists() ? firestore.get(userPath()).data : {};
    }

    function userRole() {
      return userDocExists() && userData().keys().hasAll(['role'])
        ? userData().role
        : '';
    }

    function isSuperAdmin() {
      return userRole() in ['superadmin', 'super_admin'];
    }

    function userSchoolId() {
      return userDocExists() && userData().keys().hasAll(['schoolId'])
        ? userData().schoolId
        : '';
    }

    // Roles that may manage student photos for their own school only.
    function isSchoolStaffRole() {
      return userRole() in [
        'admin',
        'school_admin',
        'assistant',
        'staff',
        'teacher'
      ];
    }

    function sameSchool(schoolId) {
      return userSchoolId() == schoolId
        && userSchoolId() is string
        && userSchoolId().size() > 0;
    }

    function canManageSchoolStudentPhotos(schoolId) {
      return isSuperAdmin()
        || (isSchoolStaffRole() && sameSchool(schoolId));
    }

    function isAllowedStudentImageUpload() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    function isStudentPhotoFileName(fileName) {
      return fileName.matches('photo_[0-9]+\\.(jpg|jpeg|png|webp)');
    }

    // 2. Profiles: Authenticated users can read all user profile images, but only owners can upload
    match /users/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // 3. School store product images (admin/assistant of same school)
    match /schools/{schoolId}/store/products/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isSuperAdmin()
        || (
          sameSchool(schoolId)
          && userRole() in ['admin', 'school_admin', 'assistant']
        )
      );
    }

    // 4. Schools: school-related images (logos, etc.) — staff of same school
    match /schools/{schoolId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if canManageSchoolStudentPhotos(schoolId);
    }

    // 5. Student photos — school-scoped, staff only, images only
    match /students/{schoolId}/{studentId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if canManageSchoolStudentPhotos(schoolId)
        && isAllowedStudentImageUpload()
        && isStudentPhotoFileName(fileName);
    }

    // Legacy generic path (superadmin only)
    match /students/{studentId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Chat attachments
    match /chat_attachments/{messageId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Legacy store image path (backward compatibility)
    match /market/{itemId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && userDocExists()
        && userRole() in ['admin', 'school_admin', 'assistant', 'superadmin', 'super_admin'];
    }

    match /system/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
