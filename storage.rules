rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Default Deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Inline path — some rule engines reject function-wrapped paths for cross-service calls.
    function userDocExists() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDocExists()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data
        : {};
    }

    // Prefer non-empty JWT custom claims (synced by server), then Firestore users/{uid}.
    // Empty-string claim schoolId is common after admin signup before activation — must not block Firestore fallback.
    function claimRole() {
      return isSignedIn()
        && request.auth.token.keys().hasAll(['role'])
        && request.auth.token.role is string
        ? request.auth.token.role
        : '';
    }

    function claimSchoolId() {
      return isSignedIn()
        && request.auth.token.keys().hasAll(['schoolId'])
        && request.auth.token.schoolId is string
        ? request.auth.token.schoolId
        : '';
    }

    function firestoreRole() {
      return userDocExists() && userData().keys().hasAll(['role'])
        ? userData().role
        : '';
    }

    function firestoreSchoolId() {
      return userDocExists() && userData().keys().hasAll(['schoolId'])
        ? userData().schoolId
        : '';
    }

    function userRole() {
      return claimRole().size() > 0 ? claimRole() : firestoreRole();
    }

    function userSchoolId() {
      return claimSchoolId().size() > 0 ? claimSchoolId() : firestoreSchoolId();
    }

    function isSuperAdmin() {
      return userRole() in ['superadmin', 'super_admin'];
    }

    // App roles (types.ts): superadmin, admin, assistant, teacher, parent, staff
    // Legacy aliases: school_admin, super_admin
    function isSchoolStaffRole() {
      return userRole() in [
        'admin',
        'school_admin',
        'assistant',
        'staff',
        'teacher'
      ];
    }

    function sameSchool(schoolId) {
      return userSchoolId() is string
        && userSchoolId().size() > 0
        && userSchoolId() == schoolId;
    }

    function canManageSchoolStudentPhotos(schoolId) {
      return isSuperAdmin()
        || (isSchoolStaffRole() && sameSchool(schoolId));
    }

    function isStudentPhotoFileName(fileName) {
      return fileName.matches('photo_[0-9]+\\.(jpg|jpeg|png|webp)');
    }

    function isAllowedStudentImageUpload(fileName) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size < 5 * 1024 * 1024
        && isStudentPhotoFileName(fileName)
        && (
          request.resource.contentType == null
          || request.resource.contentType == 'application/octet-stream'
          || request.resource.contentType.matches('image/(jpeg|jpg|png|webp)')
        );
    }

    // 2. Profiles: Authenticated users can read all user profile images, but only owners can upload
    match /users/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // 3. School store product images (admin/assistant of same school)
    match /schools/{schoolId}/store/products/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isSuperAdmin()
        || (
          sameSchool(schoolId)
          && userRole() in ['admin', 'school_admin', 'assistant']
        )
      );
    }

    // 4. Schools: school-related images (logos, etc.) — staff of same school
    match /schools/{schoolId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if canManageSchoolStudentPhotos(schoolId);
    }

    // 5. Student photos — school-scoped, staff only, images only
    match /students/{schoolId}/{studentId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if canManageSchoolStudentPhotos(schoolId)
        && isAllowedStudentImageUpload(fileName);
    }

    // Legacy generic path (superadmin only)
    match /students/{studentId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Chat attachments
    match /chat_attachments/{messageId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Legacy store image path (backward compatibility)
    match /market/{itemId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && userDocExists()
        && userRole() in ['admin', 'school_admin', 'assistant', 'superadmin', 'super_admin'];
    }

    match /system/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
