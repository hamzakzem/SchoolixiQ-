rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Default Deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // 2. Auth Helper
    function isSignedIn() {
      return request.auth != null;
    }

    // 3. Profiles: Authenticated users can read all user profile images, but only owners can upload
    match /users/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // 4. School store product images (admin/assistant of same school)
    match /schools/{schoolId}/store/products/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
        || (
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId == schoolId
          && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'assistant']
        )
      );
    }

    // 5. Schools: school-related images (logos, etc.)
    match /schools/{schoolId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId == schoolId || 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
      );
    }

    // 5. Students: Teachers and Admins can manage student photos
    match /students/{schoolId}/{studentId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId == schoolId || 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
      );
    }
    
    // Legacy generic path
    match /students/{studentId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // Attachments
    match /chat_attachments/{messageId}/{allPaths=**} {
       allow read, write: if isSignedIn();
    }
    
    // Legacy store image path (backward compatibility)
    match /market/{itemId}/{allPaths=**} {
       allow read: if isSignedIn();
       allow write: if isSignedIn() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'assistant', 'superadmin'];
    }

    match /system/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }
  }
}
