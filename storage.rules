rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Default Deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Inline path — some rule engines reject function-wrapped paths for cross-service calls.
    function userDocExists() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDocExists()
        ? firestore.get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {};
    }

    // Prefer non-empty JWT custom claims (synced by server), then Firestore users/{uid}.
    function claimRole() {
      return isSignedIn()
        && request.auth.token.keys().hasAll(['role'])
        && request.auth.token.role is string
        ? request.auth.token.role
        : '';
    }

    function claimSchoolId() {
      return isSignedIn()
        && request.auth.token.keys().hasAll(['schoolId'])
        && request.auth.token.schoolId is string
        ? request.auth.token.schoolId
        : '';
    }

    function firestoreRole() {
      return userDocExists() && userData().keys().hasAll(['role'])
        ? userData().role
        : '';
    }

    function firestoreSchoolId() {
      return userDocExists() && userData().keys().hasAll(['schoolId'])
        ? userData().schoolId
        : '';
    }

    function userRole() {
      return claimRole().size() > 0 ? claimRole() : firestoreRole();
    }

    function userSchoolId() {
      return claimSchoolId().size() > 0 ? claimSchoolId() : firestoreSchoolId();
    }

    function isSuperAdmin() {
      return userRole() in ['superadmin', 'super_admin'];
    }

    function sameSchool(schoolId) {
      return userSchoolId() is string
        && userSchoolId().size() > 0
        && userSchoolId() == schoolId;
    }

    function canManageSchoolAssets(schoolId) {
      return isSuperAdmin()
        || (
          userRole() in ['admin', 'school_admin', 'assistant', 'staff']
          && sameSchool(schoolId)
        );
    }

    function isStudentPhotoFileName(fileName) {
      return fileName.matches('photo_[0-9]+\\.(jpg|jpeg|png|webp)');
    }

    function isSchoolLogoFileName(fileName) {
      return fileName.matches('logo_[0-9]+\\.(jpg|jpeg|png|webp)');
    }

    function isStoreProductFileName(fileName) {
      return fileName.matches('[0-9]+-[^/]+\\.(jpg|jpeg|png|webp|gif)');
    }

    function isAllowedImageUpload(fileName, maxBytes) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size < maxBytes
        && fileName.matches('.*\\.(jpg|jpeg|png|webp|gif)')
        && (
          request.resource.contentType == null
          || request.resource.contentType == 'application/octet-stream'
          || request.resource.contentType.matches('image/.*')
        );
    }

    // 2. Profiles: Authenticated users can read all user profile images, but only owners can upload
    match /users/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // 3. School store product images (school admin/staff of same school)
    match /schools/{schoolId}/store/products/{fileName} {
      allow read: if isSignedIn();
      allow write: if canManageSchoolAssets(schoolId)
        && isAllowedImageUpload(fileName, 5 * 1024 * 1024)
        && isStoreProductFileName(fileName);
    }

    // 4. School logo
    match /schools/{schoolId}/logo/{fileName} {
      allow read: if isSignedIn();
      allow write: if canManageSchoolAssets(schoolId)
        && isAllowedImageUpload(fileName, 2 * 1024 * 1024)
        && isSchoolLogoFileName(fileName);
    }

    // 5. Other school assets — read only; writes use explicit logo / store paths above
    match /schools/{schoolId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // 6. Student photos — school-scoped, management staff only, images only
    match /students/{schoolId}/{studentId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if canManageSchoolAssets(schoolId)
        && isStudentPhotoFileName(fileName)
        && isAllowedImageUpload(fileName, 5 * 1024 * 1024);
    }

    // Legacy generic path (superadmin only)
    match /students/{studentId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Chat attachments
    match /chat_attachments/{messageId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Legacy store image path (backward compatibility)
    match /market/{itemId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && userDocExists()
        && userRole() in ['admin', 'school_admin', 'assistant', 'staff', 'superadmin', 'super_admin'];
    }

    match /system/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
